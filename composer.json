{
    "name": "mrhdolek/symfony-boilerplate-ddd",
    "description": "Symfony boilerplate ddd",
    "keywords": ["symfony", "php", "ddd"],
    "license": "MIT",
    "authors": [
        {
            "name": "Aleksander Kowalski",
            "email": "mrhdolek14@gmail.com",
            "homepage": "https://github.com/MrHDOLEK"
        }
    ],
    "type": "project",
    "minimum-stability": "stable",
    "require": {
        "php": "8.5.*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.5",
        "dragonmantank/cron-expression": "^3.6",
        "endroid/qr-code": "^6.1",
        "league/oauth2-client": "^2.9",
        "nelmio/api-doc-bundle": "^5.6",
        "phpdocumentor/reflection-docblock": "5.6.*",
        "promphp/prometheus_client_php": "^2.15",
        "ramsey/uuid": "4.7.*",
        "scheb/2fa-backup-code": "^8.0",
        "scheb/2fa-bundle": "^8.0",
        "scheb/2fa-totp": "^8.0",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/clock": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/discord-notifier": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/notifier": "8.1.*",
        "symfony/process": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/rate-limiter": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/slack-notifier": "8.1.*",
        "symfony/telegram-notifier": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/tailwind-bundle": "^0.13.0"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "phpunit/phpunit": "^12.3",
        "symfony/debug-bundle": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "zircote/swagger-php": "^5.3 || ^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\Unit\\": "tests/unit/",
            "App\\Tests\\Integration\\": "tests/integration/",
            "App\\Tests\\Support\\": "tests/support/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "cs:fix": "tools/mago/vendor/bin/mago format",
        "cs:check": "tools/mago/vendor/bin/mago format --check",
        "lint": [
            "tools/mago/vendor/bin/mago format --check",
            "tools/mago/vendor/bin/mago lint"
        ],
        "analyze": "tools/mago/vendor/bin/mago analyze",
        "migrate": "php bin/console doctrine:migrations:migrate -n",
        "db:test": "php bin/console doctrine:migrations:migrate -n --env=test",
        "test": "phpunit",
        "deptrac": "tools/deptrac/vendor/bin/deptrac --config-file=deptrac.yaml --formatter=table",
        "tools:install": [
            "composer install --working-dir=tools/mago",
            "composer install --working-dir=tools/deptrac"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts",
            "@tools:install"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@tools:install"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
