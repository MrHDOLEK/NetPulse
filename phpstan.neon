parameters:
    level: max
    paths:
        - src
        - config
    # G1 Foundation authors the shared config files (doctrine.php, services.php,
    # messenger.php) ONCE; they reference DBAL Type classes, handlers, listeners and
    # messages that are created by the later module groups (G2-G6). Until those
    # classes land, PHPStan flags the forward references in config as "not found".
    # These ignores are scoped to the config/ forward references only and are set to
    # NOT report when unmatched, so each entry self-heals (silently no-ops) the moment
    # its module group creates the class.
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            message: '#Class App\\Metrics\\Application\\RemoteWrite\\PushMeasurementMessage not found\.#'
            path: config/packages/messenger.php
