{% macro gauge(pct = 100, size = 180, label = 'Uptime', class = '', value_attr = '') %}
    {% set p = pct < 0 ? 0 : (pct > 100 ? 100 : pct) %}
    {% set color = p >= 99.5 ? 'var(--good)' : (p >= 98 ? 'var(--warn)' : 'var(--bad)') %}

    {% set cx = size / 2 %}
    {% set cy = size / 2 %}
    {% set r = size / 2 - 14 %}
    {% set k = r * 0.70710678 %}
    {% set x0 = cx - k %}
    {% set y0 = cy + k %}
    {% set x1 = cx + k %}
    {% set y1 = cy + k %}
    {% set d = 'M' ~ x0 ~ ',' ~ y0 ~ ' A' ~ r ~ ',' ~ r ~ ' 0 1 1 ' ~ x1 ~ ',' ~ y1 %}

    {% set arcLen = 2 * 3.14159265 * r * 0.75 %}
    {% set frac = p / 100 %}
    {% set dash = (arcLen * frac) ~ ' ' ~ arcLen %}

    <svg
        width="{{ size }}" height="{{ size }}" viewBox="0 0 {{ size }} {{ size }}"
        class="block{{ class ? ' ' ~ class : '' }}"
        role="img"
        aria-label="{{ label }} {{ p|number_format(2) }} percent"
    >
        <path d="{{ d }}" fill="none" stroke="var(--border)" stroke-width="10" stroke-linecap="round"></path>
        <path d="{{ d }}" fill="none" stroke="{{ color }}" stroke-width="10" stroke-linecap="round"
              stroke-dasharray="{{ dash }}"></path>
        <text x="{{ cx }}" y="{{ cy - 2 }}" text-anchor="middle" fill="var(--text)"
              font-size="{{ (size * 0.2)|round }}" font-family="var(--mono)" font-weight="600"
              class="tnum"{{ value_attr ? ' ' ~ value_attr|raw }}>{{ p|number_format(p == 100 ? 0 : 1) }}</text>
        <text x="{{ cx }}" y="{{ cy + (size * 0.16)|round }}" text-anchor="middle" fill="var(--text-dim)"
              font-size="12" font-family="var(--mono)">%</text>
        <text x="{{ cx }}" y="{{ cy + (size * 0.3)|round }}" text-anchor="middle" fill="var(--text-dim)"
              font-size="11" letter-spacing="1" style="text-transform: uppercase">{{ label }}</text>
    </svg>
{% endmacro %}
