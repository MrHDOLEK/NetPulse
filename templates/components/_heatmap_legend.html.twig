{% macro heatmap_legend(legend = []) %}
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <span class="text-[11px] font-medium uppercase tracking-wide text-faint">Scale</span>

        <div class="flex flex-wrap items-center gap-3">
            <template x-for="(b, i) in legend" :key="i">
                <span class="inline-flex items-center gap-1.5 text-[12px] text-dim">
                    <span class="h-3 w-3 rounded-sm border border-line" :style="b.bgStyle"></span>
                    <span class="font-mono tnum" x-text="b.label"></span>
                </span>
            </template>
        </div>

        <div class="flex flex-wrap items-center gap-3" x-show="false" x-cloak>
            {% for b in legend %}
                <span class="inline-flex items-center gap-1.5 text-[12px] text-dim">
                    <span class="h-3 w-3 rounded-sm border border-line" style="{{ b.bgStyle }}"></span>
                    <span class="font-mono tnum">{{ b.label }}</span>
                </span>
            {% endfor %}
        </div>
    </div>
{% endmacro %}
