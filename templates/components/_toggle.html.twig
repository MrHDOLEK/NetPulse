{% macro toggle(on = false, extra = '', class = '') %}
    <button
        type="button"
        role="switch"
        aria-checked="{{ on ? 'true' : 'false' }}"
        class="toggle-track relative inline-flex h-5 w-9 shrink-0 items-center rounded-full border border-line-2 transition-colors {{ on ? 'bg-accent' : 'bg-surface-2' }}{{ class ? ' ' ~ class : '' }}"
        {{ extra|raw }}
    >
        <span class="toggle-knob pointer-events-none ml-0.5 h-3.5 w-3.5 rounded-full bg-ink shadow-[var(--shadow)] transition-transform {{ on ? 'translate-x-4' : 'translate-x-0' }}"></span>
    </button>
{% endmacro %}
