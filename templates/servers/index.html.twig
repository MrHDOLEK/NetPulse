{% extends 'base.html.twig' %}

{% import 'components/_card.html.twig' as card %}
{% import 'components/_server_controls.html.twig' as server_controls %}
{% import 'components/_server_table.html.twig' as server_table %}

{% block title %}Servers · NetPulse{% endblock %}

{% block breadcrumb %}
    <span class="text-ink">Servers</span>
{% endblock %}

{% block body %}
    <div class="flex flex-col gap-5" x-data="servers">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
                <h1 class="text-[20px] font-semibold tracking-tight text-ink">Servers</h1>
                <p class="mt-0.5 text-[13px] text-dim">Per-server performance, averaged over the window.</p>
            </div>
        </div>

        {% set controls_body %}
            {{ server_controls.server_controls(window) }}
        {% endset %}
        {{ card.card(controls_body) }}

        {% set table_body %}
            {{ server_table.server_table(bootstrap.rows) }}
        {% endset %}
        {{ card.card(table_body) }}

        <script type="application/json" id="servers-bootstrap">{{ bootstrap|json_encode|raw }}</script>
    </div>
{% endblock %}
