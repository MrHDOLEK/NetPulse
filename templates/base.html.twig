<!DOCTYPE html>
<html lang="en" data-density="comfortable" class="h-full">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{{ site_name() }}{% endblock %}</title>

        {% set csp_nonce = app.request.attributes.get('csp_nonce') %}

        <script nonce="{{ csp_nonce }}">
            (function () {
                try {
                    var stored = localStorage.getItem("netpulse:dark");
                    var dark = stored === null
                        ? window.matchMedia("(prefers-color-scheme: dark)").matches
                        : stored === "dark";
                    document.documentElement.setAttribute("data-theme", dark ? "dark" : "light");
                } catch (e) {
                    document.documentElement.setAttribute("data-theme", "dark");
                }
            })();
        </script>

        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="{{ asset('vendor/uplot/dist/uPlot.min.css') }}">
        {{ importmap('app', { nonce: csp_nonce }) }}
    </head>
    <body class="h-full bg-bg font-sans text-ink antialiased">
        <div x-data="sidebar" class="flex h-full">
            <aside
                class="hidden shrink-0 flex-col border-r border-line bg-surface transition-[width] duration-200 lg:flex"
                :class="railWidthClass"
            >
                <div class="flex h-14 items-center gap-2.5 border-b border-line px-4">
                    {% include 'partials/_logo.html.twig' with { size: 30 } only %}
                    <span x-show="expanded" class="text-[15px] font-semibold tracking-tight">{{ site_name() }}</span>
                </div>

                <nav class="flex flex-1 flex-col gap-1 p-3">
                    {% set dashboard_active = app.request.attributes.get('_route') == 'dashboard' %}
                    <a
                        href="{{ path('dashboard') }}"
                        class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ dashboard_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                        {% if dashboard_active %}aria-current="page"{% endif %}
                    >
                        {% if dashboard_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                        {% include 'partials/_nav_icon.html.twig' with { name: 'dashboard', active: dashboard_active } only %}
                        <span x-show="expanded" class="flex-1 text-left">Dashboard</span>
                    </a>

                    {% set history_active = app.request.attributes.get('_route') == 'history' %}
                    <a
                        href="{{ path('history') }}"
                        class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ history_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                        {% if history_active %}aria-current="page"{% endif %}
                    >
                        {% if history_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                        {% include 'partials/_nav_icon.html.twig' with { name: 'history', active: history_active } only %}
                        <span x-show="expanded" class="flex-1 text-left">History</span>
                    </a>

                    {% set heatmap_active = app.request.attributes.get('_route') == 'heatmap' %}
                    <a
                        href="{{ path('heatmap') }}"
                        class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ heatmap_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                        {% if heatmap_active %}aria-current="page"{% endif %}
                    >
                        {% if heatmap_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                        {% include 'partials/_nav_icon.html.twig' with { name: 'heatmap', active: heatmap_active } only %}
                        <span x-show="expanded" class="flex-1 text-left">Heatmap</span>
                    </a>

                    {% set servers_active = app.request.attributes.get('_route') == 'servers' %}
                    <a
                        href="{{ path('servers') }}"
                        class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ servers_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                        {% if servers_active %}aria-current="page"{% endif %}
                    >
                        {% if servers_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                        {% include 'partials/_nav_icon.html.twig' with { name: 'server', active: servers_active } only %}
                        <span x-show="expanded" class="flex-1 text-left">Servers</span>
                    </a>

                    {% set settings_active = app.request.attributes.get('_route') starts with 'settings' %}
                    <a
                        href="{{ path('settings_security') }}"
                        class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ settings_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                        {% if settings_active %}aria-current="page"{% endif %}
                    >
                        {% if settings_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                        {% include 'partials/_nav_icon.html.twig' with { name: 'settings', active: settings_active } only %}
                        <span x-show="expanded" class="flex-1 text-left">Settings</span>
                    </a>
                </nav>

                <div class="border-t border-line p-3">
                    <button
                        type="button"
                        @click="toggleRail()"
                        class="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-[13px] text-dim transition-colors hover:bg-surface-2 hover:text-ink"
                    >
                        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path x-show="collapsed" d="m9 6 6 6-6 6"></path>
                            <path x-show="expanded" d="m15 6-6 6 6 6"></path>
                        </svg>
                        <span x-show="expanded">Collapse</span>
                    </button>
                </div>
            </aside>

            <div class="lg:hidden" x-cloak>
                <div
                    x-show="open"
                    x-transition.opacity
                    @click="closeDrawer()"
                    class="fixed inset-0 z-40 bg-black/50"
                ></div>

                <aside
                    x-show="open"
                    x-transition:enter="transition ease-out duration-200"
                    x-transition:enter-start="-translate-x-full"
                    x-transition:enter-end="translate-x-0"
                    x-transition:leave="transition ease-in duration-150"
                    x-transition:leave-start="translate-x-0"
                    x-transition:leave-end="-translate-x-full"
                    class="fixed inset-y-0 left-0 z-50 flex w-[230px] flex-col border-r border-line bg-surface"
                >
                    <div class="flex h-14 items-center justify-between gap-2.5 border-b border-line px-4">
                        <div class="flex items-center gap-2.5">
                            {% include 'partials/_logo.html.twig' with { size: 30 } only %}
                            <span class="text-[15px] font-semibold tracking-tight">{{ site_name() }}</span>
                        </div>
                        <button type="button" @click="closeDrawer()" class="grid h-8 w-8 place-items-center rounded-lg text-dim transition-colors hover:bg-surface-2 hover:text-ink" title="Close">
                            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M6 6l12 12M18 6 6 18"></path>
                            </svg>
                        </button>
                    </div>

                    <nav class="flex flex-1 flex-col gap-1 p-3">
                        {% set dashboard_active = app.request.attributes.get('_route') == 'dashboard' %}
                        <a
                            href="{{ path('dashboard') }}"
                            class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ dashboard_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                            {% if dashboard_active %}aria-current="page"{% endif %}
                        >
                            {% if dashboard_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                            {% include 'partials/_nav_icon.html.twig' with { name: 'dashboard', active: dashboard_active } only %}
                            <span class="flex-1 text-left">Dashboard</span>
                        </a>
                        {% set history_active = app.request.attributes.get('_route') == 'history' %}
                        <a
                            href="{{ path('history') }}"
                            class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ history_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                            {% if history_active %}aria-current="page"{% endif %}
                        >
                            {% if history_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                            {% include 'partials/_nav_icon.html.twig' with { name: 'history', active: history_active } only %}
                            <span class="flex-1 text-left">History</span>
                        </a>

                        {% set heatmap_active = app.request.attributes.get('_route') == 'heatmap' %}
                        <a
                            href="{{ path('heatmap') }}"
                            class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ heatmap_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                            {% if heatmap_active %}aria-current="page"{% endif %}
                        >
                            {% if heatmap_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                            {% include 'partials/_nav_icon.html.twig' with { name: 'heatmap', active: heatmap_active } only %}
                            <span class="flex-1 text-left">Heatmap</span>
                        </a>

                        {% set servers_active = app.request.attributes.get('_route') == 'servers' %}
                        <a
                            href="{{ path('servers') }}"
                            class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ servers_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                            {% if servers_active %}aria-current="page"{% endif %}
                        >
                            {% if servers_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                            {% include 'partials/_nav_icon.html.twig' with { name: 'server', active: servers_active } only %}
                            <span class="flex-1 text-left">Servers</span>
                        </a>

                        {% set settings_active = app.request.attributes.get('_route') starts with 'settings' %}
                        <a
                            href="{{ path('settings_security') }}"
                            class="group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-[13.5px] font-medium {{ settings_active ? 'bg-surface-2 text-ink' : 'text-dim hover:bg-surface-2 hover:text-ink' }}"
                            {% if settings_active %}aria-current="page"{% endif %}
                        >
                            {% if settings_active %}<span class="absolute left-0 top-1/2 h-5 w-[3px] -translate-y-1/2 rounded-r bg-accent"></span>{% endif %}
                            {% include 'partials/_nav_icon.html.twig' with { name: 'settings', active: settings_active } only %}
                            <span class="flex-1 text-left">Settings</span>
                        </a>
                    </nav>
                </aside>
            </div>

            <div class="flex min-w-0 flex-1 flex-col">
                <header class="topbar-surface flex h-14 shrink-0 items-center justify-between gap-4 border-b border-line px-4 backdrop-blur sm:px-5">
                    <div class="flex min-w-0 items-center gap-2">
                        <button
                            type="button"
                            @click="openDrawer()"
                            class="grid h-9 w-9 place-items-center rounded-lg text-dim transition-colors hover:bg-surface-2 hover:text-ink lg:hidden"
                            title="Open menu"
                            aria-label="Open menu"
                        >
                            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M4 7h16M4 12h16M4 17h16"></path>
                            </svg>
                        </button>
                        <div class="flex min-w-0 items-center gap-2 text-[13px] text-dim">
                            {% block breadcrumb %}{% endblock %}
                        </div>
                    </div>

                    <div class="flex items-center gap-1.5">
                        <button
                            type="button"
                            x-data="theme"
                            @click="toggle()"
                            class="grid h-9 w-9 place-items-center rounded-lg text-dim transition-colors hover:bg-surface-2 hover:text-ink"
                            title="Toggle theme"
                            aria-label="Toggle theme"
                        >
                            <svg x-show="dark" class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="4"></circle>
                                <path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"></path>
                            </svg>
                            <svg x-show="light" class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M20 14a8 8 0 1 1-9-11 6 6 0 0 0 9 11Z"></path>
                            </svg>
                        </button>

                        <div class="mx-1 h-6 w-px bg-line"></div>

                        {% if app.user %}
                            {% set email = app.user.userIdentifier %}
                            {% set local = email|split('@')|first %}
                            {% set parts = local|split('.')|filter(p => p is not empty) %}
                            {% if parts|length > 1 %}
                                {% set initials = (parts|first|first ~ parts|last|first)|upper %}
                            {% else %}
                                {% set initials = local|slice(0, 2)|upper %}
                            {% endif %}
                            <span class="grid h-7 w-7 place-items-center rounded-full bg-violet text-[12px] font-semibold text-white" title="{{ email }}">{{ initials }}</span>
                        {% else %}
                            <span class="grid h-7 w-7 place-items-center rounded-full bg-violet text-[12px] font-semibold text-white" aria-hidden="true">?</span>
                        {% endif %}

                        <a
                            href="/logout"
                            class="grid h-9 w-9 place-items-center rounded-lg text-dim transition-colors hover:bg-surface-2 hover:text-ink"
                            title="Sign out"
                            aria-label="Sign out"
                        >
                            <svg class="h-[17px] w-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M15 4h3a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-3"></path>
                                <path d="M10 12h9"></path>
                                <path d="m15 8 4 4-4 4"></path>
                            </svg>
                        </a>
                    </div>
                </header>

                <main class="flex-1 overflow-y-auto" style="padding: var(--pad)">
                    <div class="mx-auto max-w-[1340px]">
                        {% block body %}{% endblock %}
                    </div>
                </main>
            </div>
        </div>
    </body>
</html>
