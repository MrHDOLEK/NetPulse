{% extends 'base.html.twig' %}

{% import 'components/_card.html.twig' as card %}

{% block title %}Security · NetPulse{% endblock %}

{% block breadcrumb %}
    <span class="text-dim">Settings</span>
    <svg class="h-3.5 w-3.5 text-faint" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 6 6 6-6 6"></path>
    </svg>
    <span class="text-ink">Security</span>
{% endblock %}

{% block body %}
    <div class="mx-auto flex max-w-[640px] flex-col gap-5">
        {% include 'settings/_subnav.html.twig' %}

        <div>
            <h1 class="text-[20px] font-semibold tracking-tight text-ink">Security</h1>
            <p class="mt-0.5 text-[13px] text-dim">Protect your account with an extra step at sign-in.</p>
        </div>

        {% for type, messages in app.flashes(['success', 'error']) %}
            {% for message in messages %}
                <div
                    role="alert"
                    class="rounded-lg border px-3 py-2.5 text-[13px] {{ type == 'success'
                        ? 'border-[color-mix(in_oklab,var(--good)_45%,transparent)] bg-[color-mix(in_oklab,var(--good)_12%,transparent)] text-good'
                        : 'border-[color-mix(in_oklab,var(--bad)_45%,transparent)] bg-[color-mix(in_oklab,var(--bad)_12%,transparent)] text-bad' }}"
                >
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% set body %}
            <div class="flex flex-col gap-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                        <h2 class="text-[15px] font-semibold text-ink">Two-factor authentication</h2>
                        <p class="mt-1 max-w-md text-[13px] text-dim">
                            Require a time-based code from an authenticator app in addition to your password.
                        </p>
                    </div>

                    {% if hasTotp %}
                        <span class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-[color-mix(in_oklab,var(--good)_45%,transparent)] bg-[color-mix(in_oklab,var(--good)_12%,transparent)] px-2.5 py-1 text-[11.5px] font-medium text-good">
                            <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
                            On
                        </span>
                    {% else %}
                        <span class="inline-flex items-center gap-1.5 whitespace-nowrap rounded-full border border-line bg-surface-2 px-2.5 py-1 text-[11.5px] font-medium text-dim">
                            <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
                            Off
                        </span>
                    {% endif %}
                </div>

                {% if hasTotp %}
                    <div class="flex flex-col gap-3 border-t border-line pt-4">
                        <p class="text-[13px] text-dim">
                            Two-factor authentication is active. You can regenerate your recovery codes
                            (the old set stops working) or turn it off.
                        </p>

                        <div class="flex flex-wrap items-center gap-2.5">
                            <form method="post" action="{{ path('settings_security_2fa_recovery_regenerate') }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('twofa_regenerate') }}">
                                <button
                                    type="submit"
                                    class="inline-flex select-none items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-line-2 bg-surface-2 px-3.5 py-2 text-[13px] font-medium text-ink transition-colors hover:border-line-2 hover:bg-surface active:translate-y-px"
                                >
                                    Regenerate recovery codes
                                </button>
                            </form>
                        </div>

                        <form method="post" action="{{ path('settings_security_2fa_disable') }}" class="mt-2 flex flex-col gap-2.5 border-t border-line pt-4">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('twofa_disable') }}">
                            <label class="flex flex-col gap-1.5">
                                <span class="text-[13px] font-medium text-dim">To disable, type <span class="font-mono text-ink">DISABLE</span> below</span>
                                <input
                                    type="text"
                                    name="confirm"
                                    autocomplete="off"
                                    placeholder="DISABLE"
                                    class="max-w-[220px] rounded-lg border border-line-2 bg-surface-2 px-3 py-2 text-[14px] text-ink outline-none transition-colors placeholder:text-dim focus:border-accent"
                                >
                            </label>
                            <button
                                type="submit"
                                class="inline-flex w-fit select-none items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-[color-mix(in_oklab,var(--bad)_55%,transparent)] bg-[color-mix(in_oklab,var(--bad)_14%,transparent)] px-3.5 py-2 text-[13px] font-semibold text-bad transition-colors hover:bg-[color-mix(in_oklab,var(--bad)_22%,transparent)] active:translate-y-px"
                            >
                                Disable two-factor authentication
                            </button>
                        </form>
                    </div>
                {% else %}
                    <div class="border-t border-line pt-4">
                        <form method="post" action="{{ path('settings_security_2fa_begin') }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('twofa_begin') }}">
                            <button
                                type="submit"
                                class="inline-flex select-none items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-accent bg-accent px-3.5 py-2.5 text-[13px] font-semibold text-[oklch(0.2_0.02_250)] transition-colors hover:bg-accent-strong active:translate-y-px"
                            >
                                Set up two-factor authentication
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% endset %}
        {{ card.card(body) }}
    </div>
{% endblock %}
