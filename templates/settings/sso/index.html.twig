{% extends 'base.html.twig' %}

{% import 'components/_card.html.twig' as card %}

{% block title %}SSO · NetPulse{% endblock %}

{% block breadcrumb %}
    <span class="text-dim">Settings</span>
    <svg class="h-3.5 w-3.5 text-faint" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 6 6 6-6 6"></path>
    </svg>
    <span class="text-ink">SSO</span>
{% endblock %}

{% block body %}
    <meta name="csrf-settings-sso" content="{{ csrf_token('settings-sso') }}">

    <div
        class="mx-auto flex max-w-[680px] flex-col gap-5"
        x-data="settingsSso"
        data-secret-set="{{ secretIsSet ? '1' : '0' }}"
        data-can-encrypt="{{ canEncrypt ? '1' : '0' }}"
        data-settings='{{ {
            enabled: enabled,
            name: name,
            clientId: clientId,
            authorizationUrl: authorizationUrl,
            tokenUrl: tokenUrl,
            userInfoUrl: userInfoUrl,
            redirectUrl: redirectUrl,
            scopes: scopes
        }|json_encode|e('html_attr') }}'
    >
        {% include 'settings/_subnav.html.twig' %}

        <div>
            <h1 class="text-[20px] font-semibold tracking-tight text-ink">Single sign-on (OIDC)</h1>
            <p class="mt-0.5 text-[13px] text-dim">
                Let admins sign in through your OpenID Connect provider. SSO links to an existing NetPulse
                account by verified email — it never creates accounts.
            </p>
        </div>

        {% if not canEncrypt %}
            <div
                role="alert"
                class="rounded-lg border border-[color-mix(in_oklab,var(--bad)_45%,transparent)] bg-[color-mix(in_oklab,var(--bad)_12%,transparent)] px-3 py-2.5 text-[13px] text-bad"
            >
                The encryption key is not configured, so the client secret cannot be saved. Set
                <span class="font-mono">TOTP_ENCRYPTION_KEY</span> (or
                <span class="font-mono">SETTINGS_ENCRYPTION_KEY</span>) to a 64-character hex string and reload.
            </div>
        {% endif %}

        <div
            role="alert"
            x-show="message"
            x-cloak
            x-text="message"
            :class="alertClass"
            class="rounded-lg border px-3 py-2.5 text-[13px]"
        ></div>

        {% set field = 'rounded-lg border border-line-2 bg-surface-2 px-3 py-2 text-[14px] text-ink outline-none transition-colors placeholder:text-dim focus:border-accent' %}
        {% set lbl = 'text-[13px] font-medium text-dim' %}
        {% set legend = 'mb-2 text-[11px] font-medium uppercase tracking-wide text-faint' %}

        {% set body %}
            <div class="flex flex-col gap-6">
                <div>
                    <div class="{{ legend }}">Status</div>
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <label class="flex items-center gap-2.5">
                            <input type="checkbox" x-model="form.enabled" class="h-4 w-4 rounded border-line-2 bg-surface-2 text-accent focus:ring-accent">
                            <span class="text-[13px] font-medium text-ink">Enable SSO sign-in</span>
                        </label>
                    </div>
                    <label class="mt-3 flex max-w-[320px] flex-col gap-1.5">
                        <span class="{{ lbl }}">Button label</span>
                        <input type="text" x-model="form.name" placeholder="Company SSO" class="{{ field }}">
                    </label>
                </div>

                <div>
                    <div class="{{ legend }}">Provider</div>
                    <div class="grid grid-cols-1 gap-3">
                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Client ID</span>
                            <input type="text" x-model="form.clientId" autocomplete="off" class="{{ field }}">
                        </label>

                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">
                                Client secret
                                <span x-show="secretIsSet" x-cloak class="ml-1 inline-flex items-center gap-1 rounded-full border border-line bg-surface-2 px-2 py-0.5 text-[11px] font-medium text-dim">•••• set</span>
                            </span>
                            <input type="password" x-model="form.clientSecret" autocomplete="new-password" :placeholder="secretPlaceholder" class="{{ field }}">
                            <span class="text-[11.5px] text-faint">Stored encrypted at rest. Leave blank to keep the current secret.</span>
                        </label>

                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Authorization endpoint</span>
                            <input type="url" x-model="form.authorizationUrl" placeholder="https://idp.example/authorize" class="{{ field }}">
                        </label>
                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Token endpoint</span>
                            <input type="url" x-model="form.tokenUrl" placeholder="https://idp.example/token" class="{{ field }}">
                        </label>
                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Userinfo endpoint</span>
                            <input type="url" x-model="form.userInfoUrl" placeholder="https://idp.example/userinfo" class="{{ field }}">
                        </label>
                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Redirect URL</span>
                            <input type="url" x-model="form.redirectUrl" placeholder="https://app.example/login/oidc/callback" class="{{ field }}">
                            <span class="text-[11.5px] text-faint">Register this exact URL at your IdP.</span>
                        </label>
                        <label class="flex flex-col gap-1.5">
                            <span class="{{ lbl }}">Scopes</span>
                            <input type="text" x-model="form.scopes" placeholder="openid email profile" class="{{ field }}">
                        </label>
                    </div>
                </div>

                <div>
                    <div class="{{ legend }}">Discovery probe</div>
                    <p class="mb-3 text-[11.5px] text-faint">
                        Test reachability of your provider's discovery document. Enter an issuer or full
                        <span class="font-mono">/.well-known/openid-configuration</span> URL, or leave blank to probe the authorization endpoint above.
                    </p>
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
                        <label class="flex flex-1 flex-col gap-1.5">
                            <span class="{{ lbl }}">Issuer / discovery URL</span>
                            <input type="url" x-model="form.discoveryUrl" placeholder="https://idp.example" class="{{ field }}">
                        </label>
                        <button
                            type="button"
                            @click="test()"
                            :disabled="testing"
                            x-text="testLabel"
                            class="inline-flex select-none items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-line-2 bg-surface-2 px-3.5 py-2 text-[13px] font-medium text-ink transition-colors hover:bg-surface active:translate-y-px"
                        >Test connection</button>
                    </div>
                </div>

                <div class="flex items-center justify-end border-t border-line pt-4">
                    <button
                        type="button"
                        @click="save()"
                        :disabled="loading"
                        x-text="saveLabel"
                        class="inline-flex select-none items-center justify-center gap-2 whitespace-nowrap rounded-lg border border-accent bg-accent px-3.5 py-2 text-[13px] font-semibold text-[oklch(0.2_0.02_250)] transition-colors hover:bg-accent-strong active:translate-y-px"
                    >Save changes</button>
                </div>
            </div>
        {% endset %}
        {{ card.card(body) }}
    </div>
{% endblock %}
