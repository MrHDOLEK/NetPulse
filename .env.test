APP_ENV=test
APP_SECRET=56410c1146e3e92a4936847c83622049

DATABASE_URL=sqlite:///%kernel.project_dir%/var/netpulse_test.sqlite

MESSENGER_TRANSPORT_DSN=sync://

PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_ALLOWED_IPS=
MEASUREMENT_FRESHNESS_WINDOW=3600
NETPULSE_VERSION=test

# How long (seconds) the agent may wait before polling /due again.
AGENT_POLL_INTERVAL=60

REMOTE_WRITE_ENABLED=false
REMOTE_WRITE_URL=
REMOTE_WRITE_AUTH=
REMOTE_WRITE_EXTRA_LABELS=

NOTIFY_ENABLED=false
NOTIFY_CONSECUTIVE_THRESHOLD=3
# Tests inject transports/doubles directly; keep channels empty and the mailer discarding.
NOTIFY_CHANNELS=
NOTIFY_EMAIL_TO=
MAILER_DSN=null://null
NOTIFY_CHAT_DSN=
NOTIFY_WEBHOOK_URL=

# Fixed, throwaway 32-byte (64 hex) key so TOTP-secret encrypt/decrypt works in the test suite.
# Test-only fixture — NOT a real secret; production sets its own via TOTP_ENCRYPTION_KEY.
TOTP_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# OIDC SSO disabled in tests (empty -> isEnabled() false). The %env(string:OIDC_*)% refs must
# resolve for the container to compile; OidcLoginTest binds an enabled OidcConfig per-request.
OIDC_NAME=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_SCOPES=
OIDC_REDIRECT_URL=

# In-app settings store. Empty so tests start from ENV defaults; tests write app_settings rows to
# exercise DB-over-ENV. SETTINGS_ENCRYPTION_KEY is intentionally left UNSET so the encryptor falls
# back to the throwaway TOTP_ENCRYPTION_KEY above (secret-at-rest works); a test that needs the
# "no key" branch constructs its own encryptor with an empty key.
NETPULSE_SITE_NAME=
NETPULSE_TIMEZONE=
SETTINGS_ENCRYPTION_KEY=
